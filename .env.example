# ---------------------------------------------------------------------------
# Supabase — copy this file to `.env` and fill in real values.
# NEVER commit `.env`. The service-role key must stay server-only.
# ---------------------------------------------------------------------------

# Browser-safe (exposed to the client bundle via Vite's VITE_ prefix).
# Project URL is the BASE url only — do NOT include /rest/v1.
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
# Either name works; Lovable Cloud uses PUBLISHABLE_KEY, this repo historically used ANON_KEY.
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-publishable-key"
VITE_SUPABASE_ANON_KEY="your-anon-publishable-key"

# Server-only. No VITE_ prefix so it is never bundled into browser code.
# Used exclusively by src/integrations/supabase/client.server.ts inside
# server functions / webhooks. Bypasses Row Level Security — treat as a secret.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret-key"

# Optional: direct Postgres connection string for running migrations / the RLS
# verification script with psql or the Supabase CLI. Found in
# Supabase Dashboard -> Project Settings -> Database -> Connection string.
# SUPABASE_DB_URL="postgresql://postgres:[PASSWORD]@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"
